<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Admin Login</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body style="background:var(--bg);min-height:100vh;display:flex;align-items:center">
<div class="container">
  <div class="row justify-content-center">
    <div class="col-md-4">
      <div class="card-box text-center">
        <div style="font-size:3rem">🔐</div>
        <h3 style="color:var(--green);font-weight:800;margin:0.5rem 0">Admin Login</h3>
        <p class="text-muted small mb-4">Medical Continuity Admin Panel</p>
        <% if (error) { %><div class="alert-danger mb-3 p-3 rounded"><%= error %></div><% } %>
        <form method="POST" action="/admin/login">
          <div class="mb-3 text-start">
            <label class="form-label">Username</label>
            <input type="text" name="username" class="form-control" placeholder="admin" required>
          </div>
          <div class="mb-3 text-start">
            <label class="form-label">Password</label>
            <input type="password" name="password" class="form-control" placeholder="admin123" required>
          </div>
          <button type="submit" class="btn btn-primary w-100">Login as Admin</button>
        </form>
        <div class="mt-3 p-2 rounded" style="background:var(--green-light);font-size:0.82rem">
          Default: <strong>admin</strong> / <strong>admin123</strong>
        </div>
        <a href="/" class="d-block mt-3 text-muted small">← Home</a>
      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
