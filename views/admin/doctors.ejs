<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><title>Admin – Doctors</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<nav class="navbar navbar-expand-lg">
  <div class="container">
    <a class="navbar-brand" href="/">🏥 Medical Continuity</a>
    <div class="navbar-nav ms-auto d-flex flex-row gap-3 align-items-center">
      <a class="nav-link" href="/admin/patients">Patients</a>
      <a class="nav-link" href="/admin/doctors">Doctors</a>
      <a class="btn btn-outline-light btn-sm" href="/admin/logout">Logout</a>
    </div>
  </div>
</nav>
<div class="container py-5">
  <h3 style="color:var(--green);font-weight:800" class="mb-4">Doctor Management</h3>

  <!-- Pending -->
  <h5 class="mb-3">⏳ Pending Approval (<%= pending.length %>)</h5>
  <% if(pending.length===0){ %>
    <div class="card-box text-center py-3 mb-4"><p class="text-muted mb-0">No pending applications.</p></div>
  <% } else { %>
    <div class="row g-3 mb-4">
      <% pending.forEach(doc=>{ %>
      <div class="col-md-6">
        <div class="card-box" style="border-color:#fcd34d">
          <div class="d-flex justify-content-between mb-2">
            <div>
              <h5 style="margin:0"><%= doc.name %></h5>
              <small class="text-muted"><%= doc.email %></small>
            </div>
            <span class="badge-yellow">Pending</span>
          </div>
          <% if(doc.license){ %>
            <a href="<%= doc.license %>" target="_blank" class="btn btn-outline-primary btn-sm w-100 mb-3">View License</a>
          <% } %>
          <div class="d-flex gap-2">
            <form method="POST" action="/admin/doctors/approve/<%= doc._id %>" style="flex:1">
              <button type="submit" class="btn btn-success w-100">✓ Approve</button>
            </form>
            <form method="POST" action="/admin/doctors/reject/<%= doc._id %>" style="flex:1" onsubmit="return confirm('Reject and delete?')">
              <button type="submit" class="btn btn-danger w-100">✗ Reject</button>
            </form>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  <% } %>

  <!-- Approved -->
  <h5 class="mb-3">✅ Approved Doctors (<%= approved.length %>)</h5>
  <% if(approved.length===0){ %>
    <div class="card-box text-center py-3"><p class="text-muted mb-0">No approved doctors yet.</p></div>
  <% } else { %>
    <div class="card-box p-0" style="overflow:hidden">
      <table class="table mb-0">
        <thead><tr><th>Name</th><th>Email</th><th>License</th><th>Status</th></tr></thead>
        <tbody>
          <% approved.forEach(doc=>{ %>
          <tr>
            <td><strong><%= doc.name %></strong></td>
            <td class="text-muted"><%= doc.email %></td>
            <td><% if(doc.license){%><a href="<%= doc.license %>" target="_blank" class="btn btn-outline-primary btn-sm">View</a><% }else{%>—<% } %></td>
            <td><span class="badge-green">Active</span></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
