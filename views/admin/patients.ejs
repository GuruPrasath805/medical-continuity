<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Admin – Patients</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<nav class="navbar navbar-expand-lg">
  <div class="container">
    <a class="navbar-brand" href="/">🏥 Medical Continuity</a>
    <div class="navbar-nav ms-auto d-flex flex-row gap-3 align-items-center">
      <a class="nav-link" href="/admin/patients">Patients</a>
      <a class="nav-link" href="/admin/doctors">Doctors</a>
      <a class="btn btn-outline-light btn-sm" href="/admin/logout">Logout</a>
    </div>
  </div>
</nav>
<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3 style="color:var(--green);font-weight:800">All Patients (<%= patients.length %>)</h3>
    <a href="/admin/doctors" class="btn btn-outline-primary btn-sm">Manage Doctors →</a>
  </div>

  <% if (patients.length === 0) { %>
    <div class="card-box text-center py-5">
      <div style="font-size:3rem">👥</div>
      <p class="text-muted mt-2">No patients registered yet.</p>
      <a href="/patient/register" class="btn btn-primary mt-2">Register a Patient</a>
    </div>
  <% } else { %>
  <div class="card-box p-0" style="overflow:hidden">
    <table class="table mb-0">
      <thead>
        <tr>
          <th>#</th><th>Patient</th><th>Phone</th><th>Blood</th>
          <th>Emergency Contact</th><th>Registered</th><th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% patients.forEach((p, i) => { %>
        <tr>
          <td class="text-muted"><%= i+1 %></td>
          <td>
            <div class="d-flex align-items-center gap-2">
              <% if(p.photo){ %>
                <img src="<%= p.photo %>" style="width:36px;height:36px;border-radius:50%;object-fit:cover;border:2px solid var(--green-mid)">
              <% } else { %>
                <div style="width:36px;height:36px;border-radius:50%;background:var(--green-light);display:flex;align-items:center;justify-content:center;font-size:1rem">👤</div>
              <% } %>
              <strong><%= p.name %></strong>
            </div>
          </td>
          <td><%= p.phone %></td>
          <td><% if(p.bloodGroup){%><span class="badge-red"><%= p.bloodGroup %></span><% }else{%>—<% }%></td>
          <td><%= p.emergencyName %> — <%= p.emergencyContact %></td>
          <td class="text-muted" style="font-size:0.85rem"><%= new Date(p.createdAt).toLocaleDateString('en-IN') %></td>
          <td>
            <a href="/admin/patient/<%= p._id %>" class="btn btn-primary btn-sm">View</a>
            <a href="/admin/patient/<%= p._id %>/add-record" class="btn btn-outline-primary btn-sm ms-1">+ Add</a>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
