<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Doctor Login</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('../partials/navbar') %>
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-5">
      <div class="card-box">
        <div class="text-center mb-4">
          <div style="font-size:3rem">👨‍⚕️</div>
          <h3 style="color:var(--green);font-weight:800">Doctor Login</h3>
          <p class="text-muted small">Only admin-approved doctors can login</p>
        </div>
        <% if (error) { %><div class="alert-danger mb-3 p-3 rounded"><%= error %></div><% } %>
        <form method="POST" action="/doctor/login">
          <div class="mb-3">
            <label class="form-label">Email Address</label>
            <input type="email" name="email" class="form-control" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Password</label>
            <input type="password" name="password" class="form-control" required>
          </div>
          <button type="submit" class="btn btn-primary w-100">Sign In</button>
        </form>
        <p class="text-center mt-3"><a href="/doctor/register" style="color:var(--green)">New doctor? Register here</a></p>
        <p class="text-center"><a href="/" class="text-muted small">← Home</a></p>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
