<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Emergency Info</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body { background: linear-gradient(135deg,#dc2626,#991b1b); min-height:100vh; display:flex; align-items:center; justify-content:center; padding:1rem; }
  </style>
</head>
<body>
  <div class="emergency-card">
    <div class="emergency-badge">🚨 EMERGENCY INFORMATION</div>

    <div style="font-size:3.5rem;margin:0.5rem 0">🆘</div>

    <h3 style="color:#dc2626;font-weight:800;margin-bottom:0.25rem"><%= patient.name %></h3>
    <% if (patient.bloodGroup) { %>
      <span style="background:#fef2f2;color:#dc2626;border-radius:20px;padding:3px 14px;font-weight:700;font-size:0.9rem;display:inline-block;margin-bottom:1rem">
        Blood Group: <%= patient.bloodGroup %>
      </span>
    <% } %>

    <hr style="border-color:#fee2e2">

    <p style="color:#6b7280;font-size:0.85rem;font-weight:600;text-transform:uppercase;letter-spacing:1px;margin-bottom:0.5rem">Emergency Contact</p>
    <h4 style="font-weight:800;color:#1a2332;margin-bottom:0.25rem"><%= patient.emergencyName %></h4>
    <% if (patient.emergencyRelation) { %>
      <p style="color:#6b7280;margin-bottom:0.5rem;font-size:0.9rem">(<%= patient.emergencyRelation %>)</p>
    <% } %>
    <div class="emergency-phone"><%= patient.emergencyContact %></div>

    <a href="tel:<%= patient.emergencyContact %>" style="display:block;background:#dc2626;color:white;border-radius:10px;padding:0.75rem;font-weight:700;text-decoration:none;margin-top:1rem;font-size:1rem">
      📞 Call Now
    </a>

    <hr style="border-color:#fee2e2;margin:1rem 0">

    <p style="color:#9ca3af;font-size:0.78rem;margin:0">
      🔒 Full medical records are protected.<br>
      Doctors must login and verify with OTP to view records.
    </p>

    <a href="/doctor/login" style="display:block;background:#f9fafb;color:#374151;border-radius:8px;padding:0.5rem;font-size:0.85rem;text-decoration:none;margin-top:0.75rem;font-weight:600;border:1px solid #e5e7eb">
      👨‍⚕️ Doctor? Login to view full records
    </a>
  </div>
</body>
</html>
